{
  "expo": {
    "name": "Hilads",
    "slug": "hilads",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "scheme": "hilads",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0f0f0f",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hilads.app",
      "associatedDomains": [
        "applinks:hilads.com"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Hilads uses your location to find your city and show you what's happening nearby.",
        "NSCameraUsageDescription": "Hilads lets you send photos in city chats and event conversations.",
        "NSPhotoLibraryUsageDescription": "Hilads lets you share photos from your library in chats.",
        "NSUserNotificationUsageDescription": "Hilads sends you notifications for new messages and events in your city.",
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "softInputMode": "adjustResize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C24A38"
      },
      "package": "com.hilads.app",
      "versionCode": 3,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "hilads"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "hilads.com",
              "pathPrefix": "/e/"
            },
            {
              "scheme": "https",
              "host": "hilads.com",
              "pathPrefix": "/event/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "@sentry/react-native/expo",
      "./plugins/withSingleTopActivity",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Hilads lets you send photos in city chats and event conversations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Hilads lets you share photos from your library in chats.",
          "cameraPermission": "Hilads lets you send photos in city chats and event conversations."
        }
      ],
      [
        "expo-notifications",
        {
          "googleServicesFile": "./google-services.json",
          "color": "#FF7A3C",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hilads uses your location to find your city.",
          "locationAlwaysAndWhenInUsePermission": "Hilads uses your location to find your city."
        }
      ],
      "expo-font",
      "expo-asset",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0555a464-8dda-484b-b0a2-d61b2ad2786c"
      }
    }
  }
}
