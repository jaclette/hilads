{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8080",
        "EXPO_PUBLIC_WS_URL": "ws://10.0.2.2:8081"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "buildType": "release"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://hilads-api.onrender.com",
        "EXPO_PUBLIC_WS_URL": "wss://hilads-ws.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "buildType": "release"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://hilads-api.onrender.com",
        "EXPO_PUBLIC_WS_URL": "wss://hilads-ws.onrender.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "FILL_IN_APPLE_ID",
        "ascAppId": "FILL_IN_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "FILL_IN_TEAM_ID"
      }
    }
  }
}
