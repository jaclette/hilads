{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8080",
        "EXPO_PUBLIC_WS_URL": "ws://10.0.2.2:8081",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.hilads.live",
        "EXPO_PUBLIC_WS_URL": "wss://ws.hilads.live",
        "EXPO_PUBLIC_BASE_URL": "https://hilads.live",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.hilads.live",
        "EXPO_PUBLIC_WS_URL": "wss://ws.hilads.live",
        "EXPO_PUBLIC_BASE_URL": "https://hilads.live"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "jacques.huynh@gmail.com",
        "ascAppId": "6768905591",
        "appleTeamId": "3387URLHK7"
      }
    }
  }
}