# Backend API base URL (no trailing slash)
# Local dev: use your machine's LAN IP, not localhost (device can't reach it)
# Example: http://192.168.1.42:8080
EXPO_PUBLIC_API_URL=http://192.168.1.42:8080

# WebSocket server URL
# Same IP rule applies
EXPO_PUBLIC_WS_URL=ws://192.168.1.42:8081

# Android emulator alternative (emulator can reach host via 10.0.2.2)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
# EXPO_PUBLIC_WS_URL=ws://10.0.2.2:8081
