{
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "functions": {
    "api/prerender.mjs": {
      "includeFiles": "dist/index.html"
    }
  },
  "redirects": [
    {
      "source": "/android",
      "destination": "https://play.google.com/store/apps/details?id=com.hilads.app",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "hilads.vercel.app" }],
      "destination": "https://hilads.live/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type",  "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type",  "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type",  "value": "application/manifest+json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/logo/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml",          "destination": "/api/sitemap" },
    { "source": "/privacy",              "destination": "/privacy.html" },
    { "source": "/terms",                "destination": "/terms.html" },
    { "source": "/support",              "destination": "/support.html" },
    { "source": "/child-safety",         "destination": "/child-safety.html" },
    { "source": "/.well-known/(.*)",     "destination": "/.well-known/$1" },
    { "source": "/event/:id",            "destination": "/api/prerender?type=event&id=:id" },
    { "source": "/e/:id",                "destination": "/api/prerender?type=event&id=:id&shortlink=1" },
    { "source": "/venue/:id",            "destination": "/api/prerender?type=venue&id=:id" },
    { "source": "/city/:slug",           "destination": "/api/prerender?type=city&slug=:slug" },
    { "source": "/city/:slug/past",      "destination": "/api/prerender?type=past&slug=:slug" },
    { "source": "/city/:slug/:category", "destination": "/api/prerender?type=category&slug=:slug&category=:category" },
    { "source": "/cities",               "destination": "/api/cities-index" },

    { "source": "/:locale(fr|vi|es)/event/:id",            "destination": "/api/prerender?type=event&id=:id&locale=:locale" },
    { "source": "/:locale(fr|vi|es)/e/:id",                "destination": "/api/prerender?type=event&id=:id&shortlink=1&locale=:locale" },
    { "source": "/:locale(fr|vi|es)/venue/:id",            "destination": "/api/prerender?type=venue&id=:id&locale=:locale" },
    { "source": "/:locale(fr|vi|es)/city/:slug",           "destination": "/api/prerender?type=city&slug=:slug&locale=:locale" },
    { "source": "/:locale(fr|vi|es)/city/:slug/past",      "destination": "/api/prerender?type=past&slug=:slug&locale=:locale" },
    { "source": "/:locale(fr|vi|es)/city/:slug/:category", "destination": "/api/prerender?type=category&slug=:slug&category=:category&locale=:locale" },
    { "source": "/(fr|vi|es)/(.*)",         "destination": "/index.html" },

    { "source": "/(.*)",                 "destination": "/index.html" }
  ]
}
