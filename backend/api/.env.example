# Internal URL of the WS server, used by the PHP API to POST broadcast events.
# On Render: use the service's private network address, e.g. http://hilads-ws:8082
# Locally: http://localhost:8082
WS_INTERNAL_URL=http://localhost:8082

# WS internal auth token (must match WS_INTERNAL_TOKEN on the WS server)
WS_INTERNAL_TOKEN=

# Cloudflare account ID — visible in the R2 dashboard URL
R2_ACCOUNT_ID=your_account_id_here

# R2 API token credentials
# Create at: Cloudflare > R2 > Manage R2 API Tokens, grant Object Read + Write on your bucket
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# Bucket name (created in the R2 dashboard)
R2_BUCKET=hilads-uploads

# Public base URL for the bucket
# Enable "Public access" on the bucket to get this URL (r2.dev subdomain, one click)
# Later: replace with a custom domain e.g. https://images.hilads.app
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
